<?xml version="1.0" encoding="UTF-8"?>
<osm version="0.6">
  <!-- Lanelet2 planning map fixture (Japan region) -->
  <!-- Nodes for a 2-lanelet road segment with stop sign -->
  <node id="1" lat="35.2300" lon="136.8700"><tag k="local_x" v="0.0"/><tag k="local_y" v="3.7"/><tag k="ele" v="0.0"/></node>
  <node id="2" lat="35.2301" lon="136.8700"><tag k="local_x" v="50.0"/><tag k="local_y" v="3.7"/><tag k="ele" v="0.0"/></node>
  <node id="3" lat="35.2302" lon="136.8700"><tag k="local_x" v="100.0"/><tag k="local_y" v="3.7"/><tag k="ele" v="0.0"/></node>
  <node id="4" lat="35.2300" lon="136.8701"><tag k="local_x" v="0.0"/><tag k="local_y" v="0.0"/><tag k="ele" v="0.0"/></node>
  <node id="5" lat="35.2301" lon="136.8701"><tag k="local_x" v="50.0"/><tag k="local_y" v="0.0"/><tag k="ele" v="0.0"/></node>
  <node id="6" lat="35.2302" lon="136.8701"><tag k="local_x" v="100.0"/><tag k="local_y" v="0.0"/><tag k="ele" v="0.0"/></node>
  <node id="7" lat="35.2300" lon="136.8702"><tag k="local_x" v="0.0"/><tag k="local_y" v="-3.7"/><tag k="ele" v="0.0"/></node>
  <node id="8" lat="35.2301" lon="136.8702"><tag k="local_x" v="50.0"/><tag k="local_y" v="-3.7"/><tag k="ele" v="0.0"/></node>
  <node id="9" lat="35.2302" lon="136.8702"><tag k="local_x" v="100.0"/><tag k="local_y" v="-3.7"/><tag k="ele" v="0.0"/></node>
  <!-- Stop line nodes -->
  <node id="10" lat="35.2302" lon="136.8700"><tag k="local_x" v="98.0"/><tag k="local_y" v="3.7"/><tag k="ele" v="0.0"/></node>
  <node id="11" lat="35.2302" lon="136.8701"><tag k="local_x" v="98.0"/><tag k="local_y" v="0.0"/><tag k="ele" v="0.0"/></node>
  <!-- Sign position node -->
  <node id="12" lat="35.2302" lon="136.8700"><tag k="local_x" v="99.0"/><tag k="local_y" v="5.0"/><tag k="ele" v="2.0"/></node>

  <!-- Ways: left boundary, center boundary, right boundary -->
  <way id="100">
    <nd ref="1"/><nd ref="2"/><nd ref="3"/>
    <tag k="type" v="line_thin"/>
    <tag k="subtype" v="solid"/>
  </way>
  <way id="101">
    <nd ref="4"/><nd ref="5"/><nd ref="6"/>
    <tag k="type" v="line_thin"/>
    <tag k="subtype" v="dashed"/>
  </way>
  <way id="102">
    <nd ref="7"/><nd ref="8"/><nd ref="9"/>
    <tag k="type" v="line_thin"/>
    <tag k="subtype" v="solid"/>
  </way>
  <!-- Stop line way -->
  <way id="103">
    <nd ref="10"/><nd ref="11"/>
    <tag k="type" v="stop_line"/>
  </way>
  <!-- Sign way (traffic sign position) -->
  <way id="104">
    <nd ref="12"/>
    <tag k="type" v="traffic_sign"/>
    <tag k="subtype" v="jp_330-A"/>
  </way>

  <!-- Lanelet relations -->
  <relation id="200">
    <member type="way" ref="100" role="left"/>
    <member type="way" ref="101" role="right"/>
    <tag k="type" v="lanelet"/>
    <tag k="subtype" v="road"/>
    <tag k="speed_limit" v="40"/>
    <tag k="location" v="urban"/>
    <tag k="participant:vehicle" v="yes"/>
  </relation>
  <relation id="201">
    <member type="way" ref="101" role="left"/>
    <member type="way" ref="102" role="right"/>
    <tag k="type" v="lanelet"/>
    <tag k="subtype" v="road"/>
    <tag k="speed_limit" v="40"/>
    <tag k="location" v="urban"/>
    <tag k="participant:vehicle" v="yes"/>
  </relation>

  <!-- Regulatory element: traffic sign -->
  <relation id="300">
    <member type="way" ref="104" role="refers"/>
    <member type="way" ref="103" role="ref_line"/>
    <member type="relation" ref="200" role="lanelet"/>
    <tag k="type" v="regulatory_element"/>
    <tag k="subtype" v="traffic_sign"/>
    <tag k="traffic_sign_id" v="jp_330-A"/>
  </relation>

  <!-- Regulatory element: speed limit -->
  <relation id="301">
    <member type="relation" ref="200" role="lanelet"/>
    <member type="relation" ref="201" role="lanelet"/>
    <tag k="type" v="regulatory_element"/>
    <tag k="subtype" v="speed_limit"/>
    <tag k="sign_type" v="jp_323-40"/>
    <tag k="speed_limit" v="40"/>
    <tag k="speed_limit_unit" v="km/h"/>
  </relation>
</osm>
